{
    "layer": "top",
    "output": ["DP-1"],
    "width": 1420,
    "margin-top": 10,

    "modules-left": ["cpu", "memory", "temperature", "bluetooth"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["network", "pulseaudio", "battery", "clock", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        "format": "{icon}",
        "format-icons": {
            "active": "󰮯",
            "empty": "",
            "persistent": "󰊠",
            "default": ""
        }
    },

    "cpu": { "interval": 5, "format": "󰍛 {usage}%" },
    "memory": { "interval": 10, "format": " {used}GB" },
    "temperature": { "format": " {temperatureC}°C" },
    "bluetooth": {
        "format": "󰂯",
        "format-connected": "󰂱",
        "on-click": "blueman-manager"
    },
    "network": {
        "format-wifi": "󰤨 {bandwidthDownBits}",
        "format-ethernet": "󰈀",
        "interval": 5
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 {volume}%",
        "format-icons": { "default": ["󰕿", "󰖀", "󰕾"] },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-icons": ["󰁻", "󰁽", "󰁿", "󰂁", "󰁹"]
    },
    "clock": { "format": "{:%H:%M | %a %d}" },
    "tray": { "icon-size": 16, "spacing": 10 }
}
